# Dependencies
node_modules/
backend/node_modules/
frontend/node_modules/

# Build output
dist/
build/
coverage/
.nyc_output/
backend/coverage/
frontend/coverage/
backend/dist/
frontend/dist/
backend/build/
frontend/build/

# Logs and runtime files       
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
*.pid
*.pid.lock
*.seed

# Cache and temp files
.cache/
.temp/
.tmp/
tmp/
temp/
.vite/
.turbo/
.eslintcache
*.tsbuildinfo

# Environment and secrets
.env
.env.*
*.local
*.secret
*.secrets
*.key
*.pem
*.crt
secrets/
config/local.*

# Keep example env files tracked
!.env.example
!backend/.env.example
!frontend/.env.example

# Uploads and local storage
uploads/
storage/
public/uploads/
backend/uploads/
backend/storage/
frontend/public/uploads/

# Editor and IDE files
.vscode/
.idea/
*.suo
*.user
*.userossc
*.rsuser
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db
Desktop.ini
$RECYCLE.BIN/

# Generated archives and reports
*.tgz
*.gz
*.zip
*.tar
*.rar

# Dependency lock/debug artifacts to ignore selectively
# Keep package-lock.json tracked; ignore only transient lock files created by tools.
*.lock.pid

# Deployment and local platform config
.vercel/
.netlify/

# Ensure key project files remain trackable
!package.json
!package-lock.json
!backend/package.json
!backend/package-lock.json
!frontend/package.json
!frontend/package-lock.json
!vite.config.*
!frontend/vite.config.*
!tailwind.config.*
!frontend/tailwind.config.*
!README.md


